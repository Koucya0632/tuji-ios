# Matchfile — fastlane match (code-signing) configuration.
#
# Certificates + provisioning profiles live encrypted in a SEPARATE private
# git repo (MATCH_GIT_URL). The Fastfile lanes pass app_identifier explicitly;
# these are the defaults for ad-hoc local `bundle exec fastlane match` runs.

git_url(ENV["MATCH_GIT_URL"])
storage_mode("git")

type("appstore")

app_identifier(["app.tuji.ios", "app.tuji.ios.beta"])
