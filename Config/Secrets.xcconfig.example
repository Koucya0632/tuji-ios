// =============================================================================
// Secrets.xcconfig.example — Tuji iOS
//
// 複製為 Secrets.xcconfig 並填入實際值。Secrets.xcconfig 在 .gitignore 內。
//
//   cp Config/Secrets.xcconfig.example Config/Secrets.xcconfig
//
// 機密來源：
//   TUJI_DEV_TEAM            Apple Developer → Membership → Team ID
//   TUJI_SUPABASE_*_KEY      Supabase Dashboard → Project Settings → API
//   TUJI_GOOGLE_CLIENT_ID    GCP Console → APIs & Services → Credentials
//   TUJI_SENTRY_DSN          Sentry → Project Settings → Client Keys (DSN)
// =============================================================================

// ---------- Apple Developer ----------
TUJI_DEV_TEAM = AAAAAAAAAA          // 10 字母數字 Team ID

// ---------- Supabase（兩個 project：dev + prod）----------
TUJI_SUPABASE_PROJECT_DEV = abcdefghijklmnopqrst
TUJI_SUPABASE_PROJECT_PROD = qrstuvwxyzabcdefghij
TUJI_SUPABASE_ANON_KEY_DEV = eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TUJI_SUPABASE_ANON_KEY_PROD = eyJyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
// ⚠️ 絕對不放 service_role key — RLS 要靠它擋

// ---------- Google Sign-in ----------
TUJI_GOOGLE_CLIENT_ID = 1234567890-xxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
// reversed client ID（給 URL Scheme 用）：
TUJI_GOOGLE_REVERSED_CLIENT_ID = com.googleusercontent.apps.1234567890-xxxxxxxxxxxxxxxxxxxxx

// ---------- Sentry（v1.1 上線；v1 可填 dummy）----------
TUJI_SENTRY_DSN = https:/$()/aaaa@oxxx.ingest.sentry.io/1234567

// ---------- 注意事項 ----------
// 1. 改完這個檔不會自動觸發重 build，請 Product → Clean Build Folder
// 2. xcconfig 不支援空白後的值 — `KEY = value` 的 value 不能含空白（會被視為註解）
// 3. URL 寫 https://... 會把 // 後面當註解，要用 https:/$()/...
// 4. CI 把這檔放 GitHub Secrets，用 envsubst 或 base64 decode 寫回
