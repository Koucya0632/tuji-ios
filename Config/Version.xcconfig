// =============================================================================
// Version.xcconfig — Tuji iOS
// 唯一寫死版本號的地方。所有 scheme 都 #include 這個。
//
// MARKETING_VERSION       SemVer (App Store 顯示)
//   MAJOR  介面 / 後端不相容 / 訂閱引入時 +1
//   MINOR  新功能（Widget / Live Activity / 新語系）+1
//   PATCH  bug 修、文案、視覺微調 +1
//
// CURRENT_PROJECT_VERSION 單調遞增整數 (內部 build number)
//   每次 archive +1；CI 用 agvtool 或 GitHub run_number 自動 bump
//   手動 bump：agvtool next-version -all
// =============================================================================

MARKETING_VERSION = 1.0.0
CURRENT_PROJECT_VERSION = 2
