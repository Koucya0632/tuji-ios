// =============================================================================
// Debug.xcconfig — Tuji iOS  (本機開發 / 模擬器)
// 對應 Scheme：Tuji-Debug
// 不放機密；機密走 Secrets.xcconfig（不進 repo）
// =============================================================================

#include "Version.xcconfig"
#include? "Secrets.xcconfig"   // 用 #include?，沒有也不會 break build

// ---------- App Identity ----------
PRODUCT_BUNDLE_IDENTIFIER = app.tuji.ios.debug
PRODUCT_NAME = Tuji Dev
APP_DISPLAY_NAME = Tuji 開發

// ---------- Signing ----------
CODE_SIGN_STYLE = Automatic
DEVELOPMENT_TEAM = $(TUJI_DEV_TEAM)        // 來自 Secrets.xcconfig
CODE_SIGN_IDENTITY = Apple Development

// ---------- Deployment ----------
IPHONEOS_DEPLOYMENT_TARGET = 17.0
TARGETED_DEVICE_FAMILY = 1                  // iPhone only；2 = iPad；1,2 = 通用
SUPPORTS_MACCATALYST = NO
SUPPORTS_XR_DESIGNED_FOR_IPHONE_IPAD = NO

// ---------- Compiler ----------
SWIFT_VERSION = 6.0
SWIFT_STRICT_CONCURRENCY = complete
SWIFT_TREAT_WARNINGS_AS_ERRORS = NO
SWIFT_OPTIMIZATION_LEVEL = -Onone
SWIFT_COMPILATION_MODE = singlefile
SWIFT_ACTIVE_COMPILATION_CONDITIONS = DEBUG TUJI_DEV
ENABLE_PREVIEWS = YES
ENABLE_TESTABILITY = YES
GCC_OPTIMIZATION_LEVEL = 0
ONLY_ACTIVE_ARCH = YES
ASSETCATALOG_COMPILER_OPTIMIZATION = none

// ---------- Endpoints（公開值，可進 repo）----------
TUJI_BASE_URL = https:/$()/preview-tuji.vercel.app
TUJI_SUPABASE_URL = https:/$()/$(TUJI_SUPABASE_PROJECT_DEV).supabase.co
// ⚠️ 注意 xcconfig 把 // 視為 comment，所以 URL 用 $() 切斷

// 把以上注入到 Info.plist：在 Info.plist 寫
//   <key>TUJI_BASE_URL</key><string>$(TUJI_BASE_URL)</string>
// 然後在 Swift 內讀 Bundle.main.object(forInfoDictionaryKey: "TUJI_BASE_URL")

// ---------- Feature flags ----------
TUJI_ENABLE_LOG_VERBOSE = YES
TUJI_ENABLE_DEV_OVERLAY = YES                // 右上角浮動 build/branch 資訊
TUJI_ENABLE_RESET_BUTTON = YES               // Settings 加「清空本地」debug 按鈕

// ---------- Other Linker / Swift Flags ----------
OTHER_SWIFT_FLAGS = $(inherited) -DDEBUG -DTUJI_DEV

// ---------- 應用圖示變體（區分 dev / TestFlight / prod 圖示）----------
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon-Dev
