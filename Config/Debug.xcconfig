// =============================================================================
// Debug.xcconfig — Tuji iOS  (本機開發 / 模擬器)
// 對應 Scheme：Tuji-Debug
// 不放機密；機密走 Secrets.xcconfig（不進 repo）
// =============================================================================

#include "Version.xcconfig"
#include? "Secrets.xcconfig"   // 用 #include?，沒有也不會 break build

// ---------- App Identity ----------
// PRODUCT_BUNDLE_IDENTIFIER now takes effect (W6 Part 3 stripped the
// pbxproj target override). PRODUCT_NAME is still pinned at the
// target level to "$(TARGET_NAME)" so the bundle stays Tuji.app
// across variants — install dialog + Springboard label use
// APP_DISPLAY_NAME below.
PRODUCT_BUNDLE_IDENTIFIER = app.tuji.ios.debug
PRODUCT_NAME = Tuji Dev
APP_DISPLAY_NAME = Tuji 開發
PRODUCT_BUNDLE_PACKAGE_TYPE = APPL

// ---------- Signing ----------
CODE_SIGN_STYLE = Automatic
DEVELOPMENT_TEAM = $(TUJI_DEV_TEAM)
CODE_SIGN_IDENTITY = Apple Development
CODE_SIGN_ENTITLEMENTS = Tuji.entitlements

// ---------- Deployment ----------
IPHONEOS_DEPLOYMENT_TARGET = 18.0
TARGETED_DEVICE_FAMILY = 1
SUPPORTS_MACCATALYST = NO
SUPPORTS_XR_DESIGNED_FOR_IPHONE_IPAD = NO

// ---------- Compiler ----------
SWIFT_VERSION = 6.0
SWIFT_STRICT_CONCURRENCY = complete
SWIFT_TREAT_WARNINGS_AS_ERRORS = NO
SWIFT_OPTIMIZATION_LEVEL = -Onone
SWIFT_COMPILATION_MODE = singlefile
SWIFT_ACTIVE_COMPILATION_CONDITIONS = DEBUG TUJI_DEV
ENABLE_PREVIEWS = YES
ENABLE_TESTABILITY = YES
GCC_OPTIMIZATION_LEVEL = 0
ONLY_ACTIVE_ARCH = YES
ASSETCATALOG_COMPILER_OPTIMIZATION = none

// ---------- Info.plist (custom file, no longer synthesized) ----------
GENERATE_INFOPLIST_FILE = NO
INFOPLIST_FILE = Info.plist

// ---------- Endpoints ----------
// W1 polish: iOS Debug hits production deploy too (no stable preview alias
// for the iOS dev branch yet). iOS and Vercel both point at the same
// Supabase project (pobmxnxdftnvdmnbkmvi) so JWTs validate. Switch to a
// dedicated preview alias when iOS dev needs a separate staging tier.
TUJI_BASE_URL = https:/$()/everyday-english-picture-dictionary.vercel.app
TUJI_SUPABASE_URL = https:/$()/$(TUJI_SUPABASE_PROJECT_DEV).supabase.co
TUJI_SUPABASE_ANON_KEY = $(TUJI_SUPABASE_ANON_KEY_DEV)
// ⚠️ xcconfig 把 // 視為 comment，所以 URL 用 $() 切斷

// ---------- Feature flags ----------
TUJI_ENABLE_LOG_VERBOSE = YES
TUJI_ENABLE_DEV_OVERLAY = YES
TUJI_ENABLE_RESET_BUTTON = YES

// ---------- Other Linker / Swift Flags ----------
OTHER_SWIFT_FLAGS = $(inherited) -DDEBUG -DTUJI_DEV

// ---------- AppIcon variant (overridden by pbxproj target until variant
// art exists; intent preserved here) ----------
ASSETCATALOG_COMPILER_APPICON_NAME = AppIcon
